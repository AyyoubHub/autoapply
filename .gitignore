# Python virtual environment
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Real credentials — never commit these.
# Copy configs/config.example.json → configs/config.json and fill in.
configs/config.json
configs/jobteaser.search.json

# API keys (.env.example is committed; .env is not)
.env

# Personal resume files compiled by the AI agent
tex/

# Runtime data that accumulates during use (not committed)
scratch/*.log

# Browser binary — install separately (see README for install_browser.py)
browser/
scripts/tectonic

# Logs (generated at runtime)
logs/

# Dev scratchpad
test_run.py

# Coverage and Testing
.coverage
.coverage.*
htmlcov/
.pytest_cache/
pytest.xml

# OS and Editors
.DS_Store
.vscode/
.idea/

# Applied jobs history (any file that contains the string applied in it)
**/*applied.json
history.db
test_*.db
manual_test.db

# Ignore root .txt files but keep requirements.txt
/*.txt
!/requirements.txt